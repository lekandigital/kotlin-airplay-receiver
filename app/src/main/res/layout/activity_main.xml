<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <SurfaceView
        android:id="@+id/surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <TextView
        android:id="@+id/startup_version_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/startup_version_background"
        android:clickable="true"
        android:elevation="24dp"
        android:fontFamily="sans-serif-medium"
        android:focusable="false"
        android:letterSpacing="0.04"
        android:paddingStart="12dp"
        android:paddingTop="6dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp"
        android:soundEffectsEnabled="false"
        android:textColor="#E6FFFFFF"
        android:textSize="12sp"
        android:visibility="visible" />

    <LinearLayout
        android:id="@+id/startup_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/startup_panel_background"
        android:clickable="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="24dp"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:gravity="center_horizontal"
        android:minWidth="480dp"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingTop="26dp"
        android:paddingEnd="32dp"
        android:paddingBottom="26dp"
        android:soundEffectsEnabled="false"
        android:visibility="visible">

        <TextView
            android:id="@+id/startup_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:letterSpacing="0.02"
            android:text="@string/startup_title"
            android:textColor="#FFFFFFFF"
            android:textSize="26sp" />

        <TextView
            android:id="@+id/status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:textColor="#E6FFFFFF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/discovery_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:textColor="#99FFFFFF"
            android:textSize="12sp" />

        <View
            android:layout_width="120dp"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="#22FFFFFF" />

        <TextView
            android:id="@+id/video_mode_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:text="@string/video_mode_label"
            android:textAllCaps="true"
            android:textColor="#80FFFFFF"
            android:textSize="11sp" />

        <RadioGroup
            android:id="@+id/video_mode_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/video_mode_720p"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#E6FFFFFF"
                android:text="@string/video_mode_720p"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/video_mode_1080p"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:buttonTint="#E6FFFFFF"
                android:text="@string/video_mode_1080p"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />
        </RadioGroup>

        <TextView
            android:id="@+id/wake_mode_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:text="@string/wake_mode_label"
            android:textAllCaps="true"
            android:textColor="#80FFFFFF"
            android:textSize="11sp" />

        <RadioGroup
            android:id="@+id/wake_mode_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/wake_mode_default"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#E6FFFFFF"
                android:text="@string/wake_mode_default"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/wake_mode_always"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:buttonTint="#E6FFFFFF"
                android:text="@string/wake_mode_always"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/wake_mode_activity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:buttonTint="#E6FFFFFF"
                android:text="@string/wake_mode_activity"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />
        </RadioGroup>

        <CheckBox
            android:id="@+id/accept_audio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:buttonTint="#E6FFFFFF"
            android:checked="true"
            android:text="@string/accept_audio"
            android:textColor="#E6FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/audio_volume_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FF7DB7FF"
            android:textSize="13sp" />

        <ProgressBar
            android:id="@+id/audio_volume_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="220dp"
            android:layout_height="8dp"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progress="100"
            android:progressTint="#FF7DB7FF"
            android:progressBackgroundTint="#4DFFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/audio_volume_overlay"
        android:layout_width="72dp"
        android:layout_height="228dp"
        android:layout_gravity="center|end"
        android:layout_marginEnd="20dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/audio_volume_overlay_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:shadowColor="#E6000000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="3"
            android:textColor="#FF7DB7FF"
            android:textSize="14sp" />

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="176dp"
            android:layout_marginTop="8dp">

            <ProgressBar
                android:id="@+id/audio_volume_overlay_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="164dp"
                android:layout_height="10dp"
                android:layout_gravity="center"
                android:max="100"
                android:progress="100"
                android:progressBackgroundTint="#99000000"
                android:progressTint="#FF7DB7FF"
                android:rotation="-90" />
        </FrameLayout>
    </LinearLayout>

    <io.carmo.airplay.receiver.TrafficMonitorView
        android:id="@+id/traffic_monitor"
        android:layout_width="260dp"
        android:layout_height="140dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:clickable="true"
        android:visibility="gone" />
</FrameLayout>
