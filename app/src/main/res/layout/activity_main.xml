<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <SurfaceView
        android:id="@+id/surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <LinearLayout
        android:id="@+id/startup_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#99000000"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="visible">

        <TextView
            android:id="@+id/status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:textColor="#E6FFFFFF"
            android:textSize="18sp" />

        <RadioGroup
            android:id="@+id/wake_mode_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/wake_mode_default"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#E6FFFFFF"
                android:text="@string/wake_mode_default"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/wake_mode_always"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:buttonTint="#E6FFFFFF"
                android:text="@string/wake_mode_always"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />

            <RadioButton
                android:id="@+id/wake_mode_activity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:buttonTint="#E6FFFFFF"
                android:text="@string/wake_mode_activity"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp" />
        </RadioGroup>

        <CheckBox
            android:id="@+id/accept_audio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:buttonTint="#E6FFFFFF"
            android:checked="true"
            android:text="@string/accept_audio"
            android:textColor="#E6FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/audio_volume_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#E6FFFFFF"
            android:textSize="13sp" />

        <ProgressBar
            android:id="@+id/audio_volume_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="220dp"
            android:layout_height="8dp"
            android:layout_marginTop="4dp"
            android:max="100"
            android:progress="100"
            android:progressTint="#E6FFFFFF"
            android:progressBackgroundTint="#4DFFFFFF" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/audio_volume_overlay"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center|end"
        android:layout_marginEnd="32dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/audio_volume_overlay_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:shadowColor="#E6000000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="3"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />

        <ProgressBar
            android:id="@+id/audio_volume_overlay_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="200dp"
            android:layout_height="8dp"
            android:layout_marginTop="6dp"
            android:max="100"
            android:progress="100"
            android:progressTint="#E6FFFFFF"
            android:progressBackgroundTint="#66000000" />
    </LinearLayout>

    <io.carmo.airplay.receiver.TrafficMonitorView
        android:id="@+id/traffic_monitor"
        android:layout_width="260dp"
        android:layout_height="140dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:clickable="true"
        android:visibility="gone" />
</FrameLayout>
