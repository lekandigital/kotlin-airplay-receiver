<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <SurfaceView
        android:id="@+id/surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/ready_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="false" />

    <LinearLayout
        android:id="@+id/waiting_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/waiting_overlay_background"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:gravity="center"
        android:minWidth="520dp"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingTop="28dp"
        android:paddingEnd="32dp"
        android:paddingBottom="28dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/idle_clock_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="#FFFFFFFF"
            android:textSize="48sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/app_name_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:text="@string/startup_title"
            android:textColor="#FFFFFFFF"
            android:textSize="34sp" />

        <TextView
            android:id="@+id/device_name_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="#CCFFFFFF"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/status_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:textColor="#88FFFFFF"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/discovery_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:textColor="#66FFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/settings_button"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:focusable="true"
                android:minWidth="120dp"
                android:text="@string/settings_button"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/help_button"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="14dp"
                android:focusable="true"
                android:minWidth="96dp"
                android:text="@string/help_button"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/settings_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/settings_hint"
            android:textColor="#66FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/audio_only_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0000000"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="64dp"
        android:paddingEnd="64dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/audio_only_cover_art"
            android:layout_width="190dp"
            android:layout_height="190dp"
            android:layout_marginBottom="28dp"
            android:adjustViewBounds="true"
            android:background="#1AFFFFFF"
            android:contentDescription="@string/audio_cover_art"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <TextView
            android:id="@+id/audio_only_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:shadowColor="#CC000000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="3"
            android:text="@string/status_audio_playing"
            android:textColor="#FFFFFFFF"
            android:textSize="34sp" />

        <TextView
            android:id="@+id/audio_only_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:textColor="#CCFFFFFF"
            android:textSize="20sp" />

        <io.carmo.airplay.receiver.SpectrumVisualizerView
            android:id="@+id/audio_visualizer"
            android:layout_width="520dp"
            android:layout_height="140dp"
            android:layout_marginTop="32dp" />

        <TextView
            android:id="@+id/audio_volume_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:shadowColor="#CC000000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="3"
            android:textColor="#AAFFFFFF"
            android:textSize="16sp" />
    </LinearLayout>

    <io.carmo.airplay.receiver.TrafficMonitorView
        android:id="@+id/traffic_monitor"
        android:layout_width="260dp"
        android:layout_height="140dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/pairing_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2000000"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="64dp"
        android:paddingEnd="64dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AirPlay PIN"
            android:textColor="#FFFFFFFF"
            android:textSize="30sp" />

        <TextView
            android:id="@+id/pairing_pin_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.12"
            android:textColor="#FFFFFFFF"
            android:textSize="72sp" />

        <TextView
            android:id="@+id/pairing_hint_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="Enter this PIN on your Apple device. Native PIN verification is not enforced in this build."
            android:textColor="#BBFFFFFF"
            android:textSize="18sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/version_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="14dp"
        android:textColor="#55FFFFFF"
        android:textSize="11sp"
        android:visibility="visible" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/stream_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:visibility="gone" />

    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/quick_settings_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/stream_info_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/stream_info_background"
        android:elevation="24dp"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="12dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/stream_info_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="3dp"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/stream_info_stop_button"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:focusable="true"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/stream_action_stop"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/stream_info_fit_button"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:focusable="true"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/stream_action_screen_fit"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/stream_info_diagnostics_button"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:focusable="true"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/stream_action_diagnostics"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/stream_info_traffic_button"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:focusable="true"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/stream_action_traffic"
                android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/audio_volume_overlay"
        android:layout_width="72dp"
        android:layout_height="228dp"
        android:layout_gravity="center|end"
        android:layout_marginEnd="20dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/audio_volume_overlay_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:shadowColor="#E6000000"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="3"
            android:textColor="#FF7DB7FF"
            android:textSize="14sp" />

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="176dp"
            android:layout_marginTop="8dp">

            <ProgressBar
                android:id="@+id/audio_volume_overlay_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="164dp"
                android:layout_height="10dp"
                android:layout_gravity="center"
                android:max="100"
                android:progress="100"
                android:progressBackgroundTint="#99000000"
                android:progressTint="#FF7DB7FF"
                android:rotation="-90" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/permission_explanation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/permission_background"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingTop="14dp"
        android:paddingEnd="24dp"
        android:paddingBottom="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/permission_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="@string/permission_overlay_explanation"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp" />

        <Button
            android:id="@+id/permission_button"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:focusable="true"
            android:text="@string/permission_overlay_button"
            android:textAllCaps="false" />
    </LinearLayout>
</FrameLayout>
