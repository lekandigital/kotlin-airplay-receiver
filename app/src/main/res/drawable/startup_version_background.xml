<?xml version="1.0" encoding="utf-8"?>
<!--
    Pill-shaped background for the version label in the top-right corner.
    Opaque fill matches the startup panel so the two pieces feel like one
    surface instead of two semi-transparent rectangles floating over the
    SurfaceView (which is what produced the visual jitter on tap).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#FF101420" />
    <stroke
        android:width="1dp"
        android:color="#33FFFFFF" />
    <corners android:radius="10dp" />
</shape>
