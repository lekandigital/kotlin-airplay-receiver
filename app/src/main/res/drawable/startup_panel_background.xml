<?xml version="1.0" encoding="utf-8"?>
<!--
    Startup panel background.

    The fill is FULLY OPAQUE on purpose: drawing a translucent panel over a
    SurfaceView whose surface is still initialising produces visible
    alpha-blend shifts between frames (perceived as a flicker on tap or on
    surface-focus events). A solid gradient also reads cleaner against the
    eventual video content.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#FF1A1F2C"
        android:centerColor="#FF101420"
        android:endColor="#FF080A12"
        android:type="linear" />
    <stroke
        android:width="1dp"
        android:color="#33FFFFFF" />
    <corners android:radius="14dp" />
</shape>
